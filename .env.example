# Bot User OAuth Token (xoxb-...)
SLACK_BOT_TOKEN=xoxb-

# App-Level Token dla Socket Mode (xapp-...)
SLACK_APP_TOKEN=xapp-

# Signing Secret aplikacji Slack
SLACK_SIGNING_SECRET=

# ID użytkownika do powiadamiania (U01XXXXXXX)
# Kliknij profil → "Wyświetl profil" → ⋯ → "Kopiuj ID członka"
SLACK_USER_ID=
